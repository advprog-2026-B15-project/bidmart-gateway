# Server Configuration
SERVER_PORT=8080

# Security (JWT) - must match all services
JWT_SECRET=your_super_secret_jwt_key_here_must_be_long_enough

# Redis (for rate limiting) - use Upstash or local Redis
REDIS_HOST=localhost

# Downstream Service URLs
AUTH_SERVICE_URL=http://<auth-ec2-ip>:8081
AUCTION_SERVICE_URL=http://<auction-ec2-ip>:8083
CATALOG_SERVICE_URL=http://<catalog-ec2-ip>:8082
WALLET_SERVICE_URL=http://<wallet-ec2-ip>:8084
BOOKING_SERVICE_URL=http://<booking-ec2-ip>:8080
